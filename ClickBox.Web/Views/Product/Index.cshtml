@using ClickBox.Web.Models
@model dynamic

@{
    ViewBag.Title = "title";
}

<link href="@Url.Content("~/Content/Custom/product-table.css")" rel="stylesheet" type="text/css" />

<div ng-app="productModule" class="div-table-outer-wrapper">

    <div style="width: 60%;">
        <h2 class="pull-left">Product</h2>
        <i class="pull-right fa fa-save" style="margin-top: 20px; font-size: 26px; vertical-align: text-bottom;"></i>
    </div>
    

    <div ng-controller="productController"
         style="width: 60%;">

        <div class="div-table">
            <div class="div-table-row">
                <div class="div-table-head id-head">ID</div>
                <div class="div-table-head name-head">Name</div>
                <div class="div-table-head privkey-head">Private Key</div>
                <div class="div-table-head pubkey-head">Public Key</div>
            </div>
            <div ng-repeat="p in Products"
                 class="div-table-row"
                 ng-cloak
                 ng-click="showProductDetails({id: p.Id})">
                <div class="div-table-cell id-cell">{{p.Id}}</div>
                <div class="div-table-cell name-cell">{{p.Name}}</div>
                <div class="div-table-cell privkey-cell">{{p.PrivateKey}}</div>
                <div class="div-table-cell pubkey-cell">{{p.PublicKey}}</div>
            </div>
        </div>

        <h3 ng-if="selectedProduct"
            ng-cloak>
            Details
        </h3>

        <div ng-if="selectedProduct"
             ng-cloak>
            <div class="clearfix detail-row">
                <span class="pull-left detail-label">Product ID:</span>
                <span class="pull-left detail-value">{{selectedProduct.Id}}</span>
            </div>
            <div class="clearfix detail-row">
                <span class="pull-left detail-label">Product Name:</span>
                <span class="pull-left detail-value">{{selectedProduct.Name}}</span>
            </div>
            <div class="clearfix detail-row edit-row">
                <span class="pull-left detail-label">Private Key:</span>
                <textarea class="pull-left detail-value">{{selectedProduct.PrivateKey}}</textarea>
            </div>
            <div class="clearfix detail-row edit-row">
                <span class="pull-left detail-label">Public Key:</span>
                <textarea class="pull-left detail-value">{{selectedProduct.PublicKey}}</textarea>
            </div>
        </div>

    </div>

    

</div>



<script>

    var productModule = angular.module("productModule", []);
    var data = @Html.Raw(Json.Encode(Model));
    productModule.value("Products", data.Products);

</script>

<script src="~/AngularModules/modules/product.module.js" language="javascript"></script>













@using ClickBox.Web.Models
@model dynamic

<div ng-controller="purchaseOrderController"
     style="clear:both;"
     id="ctrlElement">
    <h1 class="product-name">{{viewModel.Product.Name}}</h1>
    <h2 class="product-description">{{viewModel.Product.Description}}</h2>
    <hr style="width:50%; float:left;">

    <div class="price-wrapper">
        <h3 class="price">Price</h3>
        <h4 class="qcat-orange">{{viewModel.Product.Price | currency:"$"}} AUD (per seat)</h4>
    </div>

    <div id="userFormWrapper">
        <form id="userForm" name="userForm">
            <div>
                <label class="lblFormItem">Contact Name</label>
                <input type="text"
                       placeholder="Contact Name"
                       ng-required="true"
                       required
                       ng-trim="true"
                       name="contact"
                       id="contact"
                       class="customer-text-detail"
                       ng-model="order.contact">
            </div>
            <div>
                <label class="lblFormItem">Organisation</label>
                <input type="text"
                       placeholder="Organisation Name"
                       ng-trim="true"
                       name="organisation"
                       id="organisation"
                       ng-required="true"
                       required
                       class="customer-text-detail"
                       ng-model="order.org">
            </div>
            <div>
                <label class="lblFormItem">Quantity</label>
                <input type="number"
                       name="quantity"
                       id="quantity"
                       ng-required="true"
                       required
                       ng-model="order.quantity"
                       max="10" min="1">
            </div>
            <button id="customButton" class="rounded-pay-btn">
                BUY NOW<i class="fa fa-chevron-right pay-icon"></i>
            </button>
        </form>
        <div id="errors">
            <ul class="validation-error">
                <li id="vContactName" class="validation-error">Please enter a valid contact name</li>
                <li id="vOrganisation" class="validation-error">Please enter an organisation name</li>
                <li id="vQuanity" class="validation-error">Please select a quanity to purchase</li>
            </ul>
        </div>
    </div>

    <div id="waitingForCharge" style="display:none;">
        <img src="~/Content/images/ajax-loader.gif"/>
        <h3>Please wait whilst your credit card purchase is being processed...</h3>
        <h4>Do not click the back in your browser.</h4>
    </div>

    <div id="oopsProblemWithCharging"  style="display:none;">
        <h3 class="failureMessageText">Sorry there seems to have been a problem.</h3>
        <div class="failureMessageText">We haven't been able to process your credit card.</div>
        <div class="failureMessageText">Please check with your credit provider and / or contact our support.</div>
        <div class="failureMessageText" ng-hide="noServer" style="margin-bottom:15px;">QCAT Support ID: {{supportIdFailedCharge}}</div>
        <a ng-hide="noServer" ng-href="http://www.qcat.com.au/contact?sid='{{supportIdFailedCharge}}'">Contact us!</a>
        <a ng-show="noServer" ng-href="http://www.qcat.com.au/contact.html">Contact us!</a>
    </div>

    <divf id="finishedPurchase" style="display:none;">
        <h2>Thank you, we received your payment of: </h2>
        <h4>{{chargedAmout | currency:"$"}} AUD</h4>
        <div class="successMessage">
            We will send your license details to 
            <span style="font-weight:bold; font-style:italic;">{{successEmail}}</span> shortly.
        </div>
    </divf>

</div>

<script src="https://checkout.stripe.com/checkout.js"></script>
<script>
    
    var handler = StripeCheckout.configure({
        key: 'pk_test_YNN22oDTqudLQp5rgaFUJGaU',
        image: '../../Content/images/stripeqcatlogo.png',
        locale: 'auto',
        token: function (token) {

            $("#userFormWrapper").hide();
            $("#waitingForCharge").show();

            // Use the token to create the charge with a server-side script.
            // You can access the token ID with `token.id`
            var scope = angular.element(document.getElementById('ctrlElement')).scope();
            //if (!scope.order.org) {
            //    scope.order.org = "None";
            //}

            scope.noServer = false;

            var qty = scope.order.quantity;
            var org = scope.order.org;
            var contact = scope.order.contact;

            console.log(token, scope);

            var charge = {
                Quantity: qty,
                Organisation: org,
                TokenId: token.id,
                Email: token.email,
                ProductId: scope.viewModel.Product.Id,
                Price: scope.viewModel.Product.Price,
                Contact: contact
            };

            console.log("The charge object for the server", charge);

            $.ajax({
                type: 'POST',
                url: '/Purchase/Charge',
                data: JSON.stringify(charge),
                contentType: 'application/json',
                success: function(data){
                    if (data.State === "Success") {
                        $("#waitingForCharge").hide();
                        $("#finishedPurchase").show();
                        scope.successEmail = data.Email;
                        scope.chargedAmout = data.ChargedAmount;
                    } else {
                        $("#waitingForCharge").hide();
                        $("#oopsProblemWithCharging").show();
                        scope.successEmail = data.Email;
                        scope.supportIdFailedCharge = data.SupportId;
                    }
                    scope.$apply();
                },
                error: function (err) {
                    $("#waitingForCharge").hide();
                    $("#oopsProblemWithCharging").show();
                    scope.noServer = true;
                    scope.$apply();
                }
            });
        }
    });

    $('#customButton').click(function(e) {
        // Open Checkout with further options
        var scope = angular.element(document.getElementById('ctrlElement')).scope();
        var valid = validateForm(scope);
        if (!valid) {
            console.log("Scope after validation failed", scope);
            return;
        }
        var qty = scope.order.quantity;
        var product = scope.viewModel.Product.Name;
        var price = scope.viewModel.Product.Price;
        handler.open({
            name: 'QCAT',
            description: qty + ' x ' + product,
            currency: "aud",
            amount: (qty * (price * 100))
        });
        e.preventDefault();
    });

    function validateForm(formFields) {

        $("#vQuanity").hide();
        $("#vContactName").hide();
        $("#vOrganisation").hide();

        if (!formFields) {
            $("#vQuanity").show();
            $("#vContactName").show();
            $("#vOrganisation").show();
            return false;
        }

        if (!formFields.order) {
            $("#vQuanity").show();
            $("#vContactName").show();
            $("#vOrganisation").show();
            return false;
        }

        var orderValid = [];

        if (!formFields.order.quantity) {
            orderValid.push(false);
            $("#vQuanity").show();
        }

        if (!formFields.order.org) {
            orderValid.push(false);
            $("#vOrganisation").show();
        }

        if (!formFields.order.contact) {
            orderValid.push(false);
            $("#vContactName").show();
        } 

        if ($.inArray(false, orderValid) > -1) {
            return false;
        }

        return true;
    }

    // Close Checkout on page navigation
    $(window).bind('popstate', function() {
        handler.close();
    });

</script>
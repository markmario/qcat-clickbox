<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://ajax.googleapis.com/ajax/libs/angular_material/0.9.4/angular-material.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=RobotoDraft:300,400,500,700,400italic">
    <meta name="viewport" content="initial-scale=1" />
    <link href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.4/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="//maxcdn.bootstrapcdn.com/font-awesome/4.3.0/css/font-awesome.min.css">
    <link href="@Url.Content("~/Content/Custom/site.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/Custom/store.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/kendo/2014.1.318/kendo.common.min.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/kendo/2014.1.318/kendo.dataviz.min.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/kendo/2014.1.318/kendo.flat.min.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/kendo/2014.1.318/kendo.dataviz.flat.min.css")" rel="stylesheet" type="text/css" />
    <script src="@Url.Content("~/Scripts/kendo/2014.1.318/jquery.min.js")"></script>
    <script src="@Url.Content("~/Scripts/kendo/2014.1.318/kendo.all.min.js")"></script>
    <script src="@Url.Content("~/Scripts/kendo/2014.1.318/kendo.aspnetmvc.min.js")"></script>
    <script src="@Url.Content("~/Scripts/kendo/2014.1.318/cultures/kendo.culture.en-AU.min.js")"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.3.15/angular.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.4/js/bootstrap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lodash.js/3.8.0/lodash.min.js"></script>
    <script type="text/javascript">
        kendo.culture("en-AU");
    </script>
    <script src="@Url.Content("~/Scripts/kendo.modernizr.custom.js")"></script>

    @Styles.Render("~/Content/Custom/site.css")
    @Styles.Render("~/Content/Custom/store.css")
</head>
<body>
    @*<nav id="nav-toggle-menu" class="navigation-list">
            <ul class="nav-list">
                <li><a href="http://www.fiftythree.com/paper">Paper</a></li>
                <li><a href="http://www.fiftythree.com/pencil">Pencil</a></li>
                <li><a href="http://shop.fiftythree.com">Shop</a></li>
                <li class="download-paper"><a href="http://itunes.apple.com/us/app/paper-by-fiftythree/id506003812?mt=8&amp;at=1l3v9Qw&amp;ct=site" target="_blank">Download</a></li>
                <li class="social fb"><a class="icon-social icon-facebook-dark" href="http://www.facebook.com/FiftyThreeInc" target="_blank">Facebook</a></li>
                <li class="social tw"><a class="icon-social icon-twitter-dark" href="http://www.twitter.com/FiftyThree" target="_blank">Twitter</a></li>
            </ul>
        </nav>*@
    <div layout="row" 
         layout-sm="column"
         ng-app="purchaseOrderModule" >
        <div flex>
            <aside>
                <h1>QCAT</h1>
                <h2>Online - Store</h2>
                <hr style="width:95%; float:left;">
                @*reder a partial with the below*@
                @Html.Partial("_PurchaseProductPicturePartial")
                
            </aside>
        </div>

        <div flex>
            <aside>
                <h1>Credit Card Payments</h1>
                <h2><i class="fa fa-lock qcat-orange" style="font-size:28px; margin-right:10px;"></i>Secure Purchase</h2>
                <hr style="width:50%; float:left;">
                @RenderBody()
            </aside>
            
            
        </div>
    </div>

    @*<div>
        @RenderBody()
    </div>*@
    @RenderSection("scripts", required: false)
    <script type="text/javascript">
        function error_handler(e) {
            if (e.errors) {
                var message = "Errors:\n";
                $.each(e.errors, function (key, value) {
                    if ('errors' in value) {
                        $.each(value.errors, function () {
                            message += this + "\n";
                        });
                    }
                });
                alert(message);
            }
        }
    </script>

    <script>

        var purchaseOrderModule = angular.module("purchaseOrderModule", []);
        var data = @Html.Raw(Json.Encode(Model));
        purchaseOrderModule.value("ViewModel", data);

    </script>

    <script src="~/AngularModules/modules/purchase-order.module.js" language="javascript"></script>

</body>
</html>
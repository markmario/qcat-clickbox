	<s:Boolean x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/PLACE_TYPE_CONSTRAINTS_ON_SAME_LINE/@EntryValue">False</s:Boolean>
	<s:Boolean x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/PLACE_WHILE_ON_NEW_LINE/@EntryValue">True</s:Boolean>
	<s:String x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/REDUNDANT_THIS_QUALIFIER_STYLE/@EntryValue">ALWAYS_USE</s:String>
	<s:String x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/SIMPLE_EMBEDDED_STATEMENT_STYLE/@EntryValue">ON_SINGLE_LINE</s:String>
	<s:Boolean x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/SPACE_AFTER_TYPECAST_PARENTHESES/@EntryValue">False</s:Boolean>
	<s:Boolean x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/SPACE_AROUND_MULTIPLICATIVE_OP/@EntryValue">True</s:Boolean>
	<s:Boolean x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/SPACE_BEFORE_SIZEOF_PARENTHESES/@EntryValue">False</s:Boolean>
	<s:Boolean x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/SPACE_BEFORE_TYPEOF_PARENTHESES/@EntryValue">False</s:Boolean>
	<s:Boolean x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/SPACE_WITHIN_SINGLE_LINE_ARRAY_INITIALIZER_BRACES/@EntryValue">True</s:Boolean>
	<s:Boolean x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/STICK_COMMENT/@EntryValue">False</s:Boolean>
	<s:Boolean x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/WRAP_AFTER_DECLARATION_LPAR/@EntryValue">True</s:Boolean>
	<s:Boolean x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/WRAP_AFTER_INVOCATION_LPAR/@EntryValue">True</s:Boolean>
	<s:String x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/WRAP_ARGUMENTS_STYLE/@EntryValue">CHOP_IF_LONG</s:String>
	<s:Boolean x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/WRAP_BEFORE_BINARY_OPSIGN/@EntryValue">True</s:Boolean>
	<s:Boolean x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/WRAP_BEFORE_FIRST_TYPE_PARAMETER_CONSTRAINT/@EntryValue">True</s:Boolean>
	<s:String x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/WRAP_EXTENDS_LIST_STYLE/@EntryValue">CHOP_IF_LONG</s:String>
	<s:String x:Key="/Default/CodeStyle/CodeFormatting/CSharpFormat/WRAP_PARAMETERS_STYLE/@EntryValue">CHOP_IF_LONG</s:String>
	<s:String x:Key="/Default/CodeStyle/CSharpFileLayoutPatterns/Pattern/@EntryValue">&lt;?xml version="1.0" encoding="utf-16"?&gt;&#xD;
&lt;Patterns xmlns="urn:schemas-jetbrains-com:member-reordering-patterns"&gt;&#xD;
  &lt;TypePattern Priority="2000" DisplayName="Type Pattern"&gt;&#xD;
    &lt;TypePattern.Match&gt;&#xD;
      &lt;And&gt;&#xD;
        &lt;Kind Is="Interface" /&gt;&#xD;
        &lt;Or&gt;&#xD;
          &lt;HasAttribute Name="System.Runtime.InteropServices.InterfaceTypeAttribute" /&gt;&#xD;
          &lt;HasAttribute Name="System.Runtime.InteropServices.ComImport" /&gt;&#xD;
        &lt;/Or&gt;&#xD;
      &lt;/And&gt;&#xD;
    &lt;/TypePattern.Match&gt;&#xD;
  &lt;/TypePattern&gt;&#xD;
  &lt;TypePattern Priority="2000" DisplayName="Type Pattern"&gt;&#xD;
    &lt;TypePattern.Match&gt;&#xD;
      &lt;And&gt;&#xD;
        &lt;Or&gt;&#xD;
          &lt;Kind Is="Struct" /&gt;&#xD;
          &lt;Kind Is="Class" /&gt;&#xD;
        &lt;/Or&gt;&#xD;
        &lt;HasAttribute Name="System.Runtime.InteropServices.StructLayoutAttribute" /&gt;&#xD;
      &lt;/And&gt;&#xD;
    &lt;/TypePattern.Match&gt;&#xD;
  &lt;/TypePattern&gt;&#xD;
  &lt;TypePattern Priority="2000" DisplayName="Type Pattern"&gt;&#xD;
    &lt;TypePattern.Match&gt;&#xD;
      &lt;And&gt;&#xD;
        &lt;Kind Is="Class" /&gt;&#xD;
        &lt;Name Is=".*NativeMethods" /&gt;&#xD;
      &lt;/And&gt;&#xD;
    &lt;/TypePattern.Match&gt;&#xD;
  &lt;/TypePattern&gt;&#xD;
  &lt;TypePattern Priority="1000" DisplayName="Type Pattern"&gt;&#xD;
    &lt;TypePattern.Match&gt;&#xD;
      &lt;Or&gt;&#xD;
        &lt;Kind Is="Class" /&gt;&#xD;
        &lt;Kind Is="Struct" /&gt;&#xD;
        &lt;Kind Is="Interface" /&gt;&#xD;
      &lt;/Or&gt;&#xD;
    &lt;/TypePattern.Match&gt;&#xD;
    &lt;Region Name="Constants"&gt;&#xD;
      &lt;Entry DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;Kind Is="Constant" /&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Static Fields"&gt;&#xD;
      &lt;Entry DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;And&gt;&#xD;
            &lt;Kind Is="Field" /&gt;&#xD;
            &lt;Static /&gt;&#xD;
          &lt;/And&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
          &lt;Readonly /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Fields"&gt;&#xD;
      &lt;Entry DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;Kind Is="Field" /&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
          &lt;Readonly /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Constructors and Destructors"&gt;&#xD;
      &lt;Entry Priority="200" DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;Or&gt;&#xD;
            &lt;Kind Is="Constructor" /&gt;&#xD;
            &lt;Kind Is="Destructor" /&gt;&#xD;
          &lt;/Or&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;Static /&gt;&#xD;
          &lt;Kind Order="Constructor Destructor" /&gt;&#xD;
          &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Delegates"&gt;&#xD;
      &lt;Entry DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;Kind Is="Delegate" /&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
          &lt;Static /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Public Events"&gt;&#xD;
      &lt;Entry DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;And&gt;&#xD;
            &lt;Kind Is="Event" /&gt;&#xD;
            &lt;Access Is="Public" /&gt;&#xD;
          &lt;/And&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;Access Order="Public" /&gt;&#xD;
          &lt;Static /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Explicit Interface Events"&gt;&#xD;
      &lt;Entry DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;And&gt;&#xD;
            &lt;Kind Is="Event" /&gt;&#xD;
            &lt;ImplementsInterface /&gt;&#xD;
          &lt;/And&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;ImplementsInterface Immediate="True" /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Events"&gt;&#xD;
      &lt;Entry DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;Kind Is="Event" /&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
          &lt;Static /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Enums"&gt;&#xD;
      &lt;Entry DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;Kind Is="Enum" /&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Interfaces"&gt;&#xD;
      &lt;Entry DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;Kind Is="Interface" /&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Public Properties"&gt;&#xD;
      &lt;Entry DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;And&gt;&#xD;
            &lt;Kind Is="Property" /&gt;&#xD;
            &lt;Access Is="Public" /&gt;&#xD;
          &lt;/And&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;Access Order="Public" /&gt;&#xD;
          &lt;Static /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Explicit Interface Properties"&gt;&#xD;
      &lt;Entry DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;And&gt;&#xD;
            &lt;Kind Is="Property" /&gt;&#xD;
            &lt;ImplementsInterface /&gt;&#xD;
          &lt;/And&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;ImplementsInterface Immediate="True" /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Properties"&gt;&#xD;
      &lt;Entry DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;Kind Is="Property" /&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
          &lt;Static /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Public Indexers"&gt;&#xD;
      &lt;Entry Priority="1000" DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;And&gt;&#xD;
            &lt;Kind Is="Indexer" /&gt;&#xD;
            &lt;Access Is="Public" /&gt;&#xD;
          &lt;/And&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;Access Order="Public" /&gt;&#xD;
          &lt;Static /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Explicit Interface Indexers"&gt;&#xD;
      &lt;Entry Priority="1000" DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;And&gt;&#xD;
            &lt;Kind Is="Indexer" /&gt;&#xD;
            &lt;ImplementsInterface /&gt;&#xD;
          &lt;/And&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;ImplementsInterface Immediate="True" /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Indexers"&gt;&#xD;
      &lt;Entry Priority="1000" DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;Kind Is="Indexer" /&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
          &lt;Static /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Public Methods and Operators"&gt;&#xD;
      &lt;Entry DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;And&gt;&#xD;
            &lt;Or&gt;&#xD;
              &lt;Kind Is="Method" /&gt;&#xD;
              &lt;Kind Is="Operator" /&gt;&#xD;
            &lt;/Or&gt;&#xD;
            &lt;Access Is="Public" /&gt;&#xD;
          &lt;/And&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;Access Order="Public" /&gt;&#xD;
          &lt;Static /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Explicit Interface Methods"&gt;&#xD;
      &lt;Entry DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;And&gt;&#xD;
            &lt;Kind Is="Method" /&gt;&#xD;
            &lt;ImplementsInterface /&gt;&#xD;
          &lt;/And&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;ImplementsInterface Immediate="True" /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Methods"&gt;&#xD;
      &lt;Entry DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;Kind Is="Method" /&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
          &lt;Static /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Region Name="Operators"&gt;&#xD;
      &lt;Entry DisplayName="Entry"&gt;&#xD;
        &lt;Entry.Match&gt;&#xD;
          &lt;Kind Is="Operator" /&gt;&#xD;
        &lt;/Entry.Match&gt;&#xD;
        &lt;Entry.SortBy&gt;&#xD;
          &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
          &lt;Static /&gt;&#xD;
          &lt;Name /&gt;&#xD;
        &lt;/Entry.SortBy&gt;&#xD;
      &lt;/Entry&gt;&#xD;
    &lt;/Region&gt;&#xD;
    &lt;Entry Priority="600" DisplayName="Entry"&gt;&#xD;
      &lt;Entry.Match&gt;&#xD;
        &lt;Kind Is="Struct" /&gt;&#xD;
      &lt;/Entry.Match&gt;&#xD;
      &lt;Entry.SortBy&gt;&#xD;
        &lt;Static /&gt;&#xD;
        &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
        &lt;Name /&gt;&#xD;
      &lt;/Entry.SortBy&gt;&#xD;
    &lt;/Entry&gt;&#xD;
    &lt;Entry Priority="700" DisplayName="Entry"&gt;&#xD;
      &lt;Entry.Match&gt;&#xD;
        &lt;Kind Is="Class" /&gt;&#xD;
      &lt;/Entry.Match&gt;&#xD;
      &lt;Entry.SortBy&gt;&#xD;
        &lt;Static /&gt;&#xD;
        &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
        &lt;Name /&gt;&#xD;
      &lt;/Entry.SortBy&gt;&#xD;
    &lt;/Entry&gt;&#xD;
    &lt;Entry DisplayName="Entry" /&gt;&#xD;
  &lt;/TypePattern&gt;&#xD;
&lt;/Patterns&gt;</s:String>
	<s:String x:Key="/Default/CodeStyle/CSharpMemberOrderPattern/CustomPattern/@EntryValue">&lt;?xml version="1.0" encoding="utf-16"?&gt;&#xD;
&lt;Patterns xmlns="urn:schemas-jetbrains-com:member-reordering-patterns"&gt;&#xD;
  &lt;TypePattern DisplayName="COM interfaces"&gt;&#xD;
    &lt;TypePattern.Match&gt;&#xD;
      &lt;Or&gt;&#xD;
        &lt;And&gt;&#xD;
          &lt;Kind Is="Interface" /&gt;&#xD;
          &lt;Or&gt;&#xD;
            &lt;HasAttribute Name="System.Runtime.InteropServices.InterfaceTypeAttribute" /&gt;&#xD;
            &lt;HasAttribute Name="System.Runtime.InteropServices.ComImport" /&gt;&#xD;
          &lt;/Or&gt;&#xD;
        &lt;/And&gt;&#xD;
      &lt;/Or&gt;&#xD;
    &lt;/TypePattern.Match&gt;&#xD;
  &lt;/TypePattern&gt;&#xD;
  &lt;TypePattern DisplayName="P/Invoke structs"&gt;&#xD;
    &lt;TypePattern.Match&gt;&#xD;
      &lt;And&gt;&#xD;
        &lt;Or&gt;&#xD;
          &lt;Kind Is="Struct" /&gt;&#xD;
          &lt;Kind Is="Class" /&gt;&#xD;
        &lt;/Or&gt;&#xD;
        &lt;HasAttribute Name="System.Runtime.InteropServices.StructLayoutAttribute" /&gt;&#xD;
      &lt;/And&gt;&#xD;
    &lt;/TypePattern.Match&gt;&#xD;
  &lt;/TypePattern&gt;&#xD;
  &lt;TypePattern DisplayName="P/Invoke classes (called xxxNativeMethods)"&gt;&#xD;
    &lt;TypePattern.Match&gt;&#xD;
      &lt;And&gt;&#xD;
        &lt;Kind Is="Class" /&gt;&#xD;
        &lt;Name Is=".*NativeMethods" /&gt;&#xD;
      &lt;/And&gt;&#xD;
    &lt;/TypePattern.Match&gt;&#xD;
  &lt;/TypePattern&gt;&#xD;
  &lt;TypePattern DisplayName="StyleCop pattern" RemoveRegions="AllExceptGenerated" Priority="100"&gt;&#xD;
    &lt;TypePattern.Match&gt;&#xD;
      &lt;Or&gt;&#xD;
        &lt;Kind Is="Class" /&gt;&#xD;
        &lt;Kind Is="Struct" /&gt;&#xD;
        &lt;Kind Is="Interface" /&gt;&#xD;
      &lt;/Or&gt;&#xD;
    &lt;/TypePattern.Match&gt;&#xD;
    &lt;Entry DisplayName="Constants"&gt;&#xD;
      &lt;Entry.Match&gt;&#xD;
        &lt;Kind Is="Constant" /&gt;&#xD;
      &lt;/Entry.Match&gt;&#xD;
      &lt;Entry.SortBy&gt;&#xD;
        &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
      &lt;/Entry.SortBy&gt;&#xD;
    &lt;/Entry&gt;&#xD;
    &lt;Entry DisplayName="Static Fields"&gt;&#xD;
      &lt;Entry.Match&gt;&#xD;
        &lt;And&gt;&#xD;
          &lt;Kind Is="Field" /&gt;&#xD;
          &lt;Static /&gt;&#xD;
        &lt;/And&gt;&#xD;
      &lt;/Entry.Match&gt;&#xD;
      &lt;Entry.SortBy&gt;&#xD;
        &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
        &lt;Readonly /&gt;&#xD;
      &lt;/Entry.SortBy&gt;&#xD;
    &lt;/Entry&gt;&#xD;
    &lt;Entry DisplayName="Fields"&gt;&#xD;
      &lt;Entry.Match&gt;&#xD;
        &lt;Kind Is="Field" /&gt;&#xD;
      &lt;/Entry.Match&gt;&#xD;
      &lt;Entry.SortBy&gt;&#xD;
        &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
        &lt;Readonly /&gt;&#xD;
      &lt;/Entry.SortBy&gt;&#xD;
    &lt;/Entry&gt;&#xD;
    &lt;Entry DisplayName="Constructors and destructors" Priority="150"&gt;&#xD;
      &lt;Entry.Match&gt;&#xD;
        &lt;Or&gt;&#xD;
          &lt;Kind Is="Constructor" /&gt;&#xD;
          &lt;Kind Is="Destructor" /&gt;&#xD;
        &lt;/Or&gt;&#xD;
      &lt;/Entry.Match&gt;&#xD;
      &lt;Entry.SortBy&gt;&#xD;
        &lt;Static /&gt;&#xD;
        &lt;Kind Order="Constructor Destructor" /&gt;&#xD;
        &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
      &lt;/Entry.SortBy&gt;&#xD;
    &lt;/Entry&gt;&#xD;
&#xD;
 &lt;Entry DisplayName="Delegates"&gt;&#xD;
    &lt;Entry.Match&gt;&#xD;
      &lt;Kind Is="delegate"/&gt;&#xD;
    &lt;/Entry.Match&gt;&#xD;
    &lt;Entry.SortBy&gt;&#xD;
      &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
      &lt;Static /&gt;&#xD;
      &lt;!-- &lt;Name/&gt; --&gt;&#xD;
    &lt;/Entry.SortBy&gt;&#xD;
    &lt;!-- &lt;Group Region="Delegates"/&gt; --&gt;&#xD;
  &lt;/Entry&gt;&#xD;
&#xD;
  &lt;Entry DisplayName="Public Events"&gt;&#xD;
    &lt;Entry.Match&gt;&#xD;
      &lt;And&gt;&#xD;
        &lt;Kind Is="event"/&gt;&#xD;
        &lt;Access Is="public"/&gt;&#xD;
      &lt;/And&gt;&#xD;
    &lt;/Entry.Match&gt;&#xD;
    &lt;Entry.SortBy&gt;&#xD;
      &lt;Static /&gt;&#xD;
      &lt;!-- &lt;Name/&gt; --&gt;&#xD;
    &lt;/Entry.SortBy&gt;&#xD;
    &lt;!-- &lt;Group Region="Public Events"/&gt; --&gt;&#xD;
  &lt;/Entry&gt;&#xD;
&#xD;
  &lt;Entry DisplayName="Interface events"&gt;&#xD;
    &lt;Entry.Match&gt;&#xD;
      &lt;And&gt;&#xD;
        &lt;Kind Is="event"/&gt;&#xD;
        &lt;ImplementsInterface/&gt;&#xD;
      &lt;/And&gt;&#xD;
    &lt;/Entry.Match&gt;&#xD;
    &lt;Entry.SortBy&gt;&#xD;
      &lt;ImplementsInterface Immediate="true"/&gt;&#xD;
      &lt;!-- &lt;Name/&gt; --&gt;&#xD;
    &lt;/Entry.SortBy&gt;&#xD;
    &lt;!-- &lt;Group Region="Explicit Interface Events" /&gt; --&gt;&#xD;
  &lt;/Entry&gt;&#xD;
&#xD;
  &lt;Entry DisplayName="Other events"&gt;&#xD;
    &lt;Entry.Match&gt;&#xD;
      &lt;Kind Is="event"/&gt;&#xD;
    &lt;/Entry.Match&gt;&#xD;
    &lt;Entry.SortBy&gt;&#xD;
      &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
      &lt;Static /&gt;&#xD;
      &lt;!-- &lt;Name/&gt; --&gt;&#xD;
    &lt;/Entry.SortBy&gt;&#xD;
    &lt;!-- &lt;Group Region="Events"/&gt; --&gt;&#xD;
  &lt;/Entry&gt;&#xD;
&#xD;
  &lt;Entry DisplayName= "Enums"&gt;&#xD;
    &lt;Entry.Match&gt;&#xD;
      &lt;Kind Is="enum"/&gt;&#xD;
    &lt;/Entry.Match&gt;&#xD;
    &lt;Entry.SortBy&gt;&#xD;
      &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
      &lt;!-- &lt;Name/&gt; --&gt;&#xD;
    &lt;/Entry.SortBy&gt;&#xD;
    &lt;!-- &lt;Group Region="Enums"/&gt; --&gt;&#xD;
  &lt;/Entry&gt;&#xD;
&#xD;
  &lt;Entry DisplayName = "Interfaces"&gt;&#xD;
    &lt;Entry.Match&gt;&#xD;
      &lt;Kind Is="interface" /&gt;&#xD;
    &lt;/Entry.Match&gt;&#xD;
    &lt;Entry.SortBy&gt;&#xD;
      &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
      &lt;!-- &lt;Name/&gt; --&gt;&#xD;
    &lt;/Entry.SortBy&gt;&#xD;
    &lt;!-- &lt;Group Region="Interfaces"/&gt; --&gt;&#xD;
  &lt;/Entry&gt;&#xD;
&#xD;
  &lt;Entry DisplayName = "Public properties"&gt;&#xD;
    &lt;Entry.Match&gt;&#xD;
      &lt;And&gt;&#xD;
        &lt;Kind Is="property"/&gt;&#xD;
        &lt;Access Is="public"/&gt;&#xD;
      &lt;/And&gt;&#xD;
    &lt;/Entry.Match&gt;&#xD;
    &lt;Entry.SortBy&gt;&#xD;
      &lt;Static/&gt;&#xD;
      &lt;!-- &lt;Name/&gt; --&gt;&#xD;
    &lt;/Entry.SortBy&gt;&#xD;
    &lt;!-- &lt;Group Region="Public Properties"/&gt; --&gt;&#xD;
  &lt;/Entry&gt;&#xD;
&#xD;
  &lt;Entry DisplayName = "Interface properties"&gt;&#xD;
    &lt;Entry.Match&gt;&#xD;
      &lt;And&gt;&#xD;
        &lt;Kind Is="property"/&gt;&#xD;
        &lt;ImplementsInterface/&gt;&#xD;
      &lt;/And&gt;&#xD;
    &lt;/Entry.Match&gt;&#xD;
    &lt;Entry.SortBy&gt;&#xD;
      &lt;ImplementsInterface Immediate="true"/&gt;&#xD;
      &lt;!-- &lt;Name/&gt; --&gt;&#xD;
    &lt;/Entry.SortBy&gt;&#xD;
    &lt;!-- &lt;Group Region="Explicit Interface Properties" /&gt; --&gt;&#xD;
  &lt;/Entry&gt;&#xD;
&#xD;
  &lt;Entry DisplayName="Other properties"&gt;&#xD;
    &lt;Entry.Match&gt;&#xD;
      &lt;Kind Is="property"/&gt;&#xD;
    &lt;/Entry.Match&gt;&#xD;
    &lt;Entry.SortBy&gt;&#xD;
      &lt;Access Order="Public Internal ProtectedInternal Protected Private"/&gt;&#xD;
      &lt;Static/&gt;&#xD;
      &lt;!-- &lt;Name/&gt; --&gt;&#xD;
    &lt;/Entry.SortBy&gt;&#xD;
    &lt;!-- &lt;Group Region="Properties"/&gt; --&gt;&#xD;
  &lt;/Entry&gt;&#xD;
&#xD;
  &lt;Entry DisplayName="Public indexers" Priority="100"&gt;&#xD;
    &lt;Entry.Match&gt;&#xD;
      &lt;And&gt;&#xD;
        &lt;Kind Is="indexer"/&gt;&#xD;
        &lt;Access Is="public"/&gt;&#xD;
      &lt;/And&gt;&#xD;
    &lt;/Entry.Match&gt;&#xD;
    &lt;Entry.SortBy&gt;&#xD;
      &lt;Static/&gt;&#xD;
      &lt;!-- &lt;Name/&gt; --&gt;&#xD;
    &lt;/Entry.SortBy&gt;&#xD;
    &lt;!-- &lt;Group Region="Public Indexers"/&gt; --&gt;&#xD;
  &lt;/Entry&gt;&#xD;
&#xD;
  &lt;Entry DisplayName="Interface indexers"&gt;&#xD;
    &lt;Entry.Match&gt;&#xD;
      &lt;And&gt;&#xD;
        &lt;Kind Is="indexer"/&gt;&#xD;
        &lt;ImplementsInterface/&gt;&#xD;
      &lt;/And&gt;&#xD;
    &lt;/Entry.Match&gt;&#xD;
    &lt;Entry.SortBy&gt;&#xD;
      &lt;ImplementsInterface Immediate="true"/&gt;&#xD;
      &lt;!-- &lt;Name/&gt; --&gt;&#xD;
    &lt;/Entry.SortBy&gt;&#xD;
    &lt;!-- &lt;Group Region="Explicit Interface Indexers" /&gt; --&gt;&#xD;
  &lt;/Entry&gt;&#xD;
&#xD;
  &lt;Entry DisplayName = "Other indexers" Priority = "100"&gt;&#xD;
    &lt;Entry.Match&gt;&#xD;
      &lt;Kind Is="indexer"/&gt;&#xD;
    &lt;/Entry.Match&gt;&#xD;
    &lt;Entry.SortBy&gt;&#xD;
      &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
      &lt;Static/&gt;&#xD;
      &lt;!-- &lt;Name/&gt; --&gt;&#xD;
    &lt;/Entry.SortBy&gt;&#xD;
    &lt;!-- &lt;Group Region="Indexers"/&gt; --&gt;&#xD;
  &lt;/Entry&gt;&#xD;
&#xD;
  &lt;Entry DisplayName="Public methods (includes operators)"&gt;&#xD;
    &lt;Entry.Match&gt;&#xD;
      &lt;And&gt;&#xD;
        &lt;Or&gt;&#xD;
          &lt;Kind Is="method"/&gt;&#xD;
          &lt;Kind Is="operator"/&gt;&#xD;
        &lt;/Or&gt;&#xD;
        &lt;Access Is="public"/&gt;&#xD;
      &lt;/And&gt;&#xD;
    &lt;/Entry.Match&gt;&#xD;
    &lt;Entry.SortBy&gt;&#xD;
      &lt;Static/&gt;&#xD;
      &lt;!-- &lt;Name/&gt; --&gt;&#xD;
    &lt;/Entry.SortBy&gt;&#xD;
    &lt;!-- &lt;Group Region="Public Methods and Operators"/&gt; --&gt;&#xD;
  &lt;/Entry&gt;&#xD;
&#xD;
  &lt;Entry DisplayName = "Interface methods"&gt;&#xD;
    &lt;Entry.Match&gt;&#xD;
      &lt;And&gt;&#xD;
        &lt;Kind Is="method"/&gt;&#xD;
        &lt;ImplementsInterface/&gt;&#xD;
      &lt;/And&gt;&#xD;
    &lt;/Entry.Match&gt;&#xD;
    &lt;Entry.SortBy&gt;&#xD;
      &lt;ImplementsInterface Immediate="true"/&gt;&#xD;
      &lt;!-- &lt;Name/&gt; --&gt;&#xD;
    &lt;/Entry.SortBy&gt;&#xD;
    &lt;!-- &lt;Group Region="Explicit Interface Methods" /&gt; --&gt;&#xD;
  &lt;/Entry&gt;&#xD;
&#xD;
  &lt;Entry DisplayName = "Other methods"&gt;&#xD;
    &lt;Entry.Match&gt;&#xD;
      &lt;Kind Is="method"/&gt;&#xD;
    &lt;/Entry.Match&gt;&#xD;
    &lt;Entry.SortBy&gt;&#xD;
      &lt;Access Order="Public Internal ProtectedInternal Protected Private"/&gt;&#xD;
      &lt;Static/&gt;&#xD;
      &lt;!-- &lt;Name/&gt; --&gt;&#xD;
    &lt;/Entry.SortBy&gt;&#xD;
    &lt;!-- &lt;Group Region="Methods"/&gt; --&gt;&#xD;
  &lt;/Entry&gt;&#xD;
&#xD;
  &lt;Entry DisplayName = "Operators"&gt;&#xD;
    &lt;Entry.Match&gt;&#xD;
      &lt;Kind Is="operator"/&gt;&#xD;
    &lt;/Entry.Match&gt;&#xD;
    &lt;Entry.SortBy&gt;&#xD;
      &lt;Access Order="Public Internal ProtectedInternal Protected Private" /&gt;&#xD;
      &lt;Static/&gt;&#xD;
      &lt;!-- &lt;Name/&gt; --&gt;&#xD;
    &lt;/Entry.SortBy&gt;&#xD;
    &lt;!-- &lt;Group Region="Operators"/&gt; --&gt;&#xD;
  &lt;/Entry&gt;&#xD;
&#xD;
  &lt;Entry DisplayName = "Nested structs" Priority = "60"&gt;&#xD;
